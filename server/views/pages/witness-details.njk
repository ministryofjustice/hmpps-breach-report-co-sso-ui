{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + " - RO and Witness Details" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  {% from "moj/components/side-navigation/macro.njk" import mojSideNavigation %}
  {% from "govuk/components/panel/macro.njk" import govukPanel %}
  {% from "govuk/components/select/macro.njk" import govukSelect %}
  {% from "govuk/components/details/macro.njk" import govukDetails %}
  {% from "govuk/components/radios/macro.njk" import govukRadios %}
  {% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
  {% from "govuk/components/button/macro.njk" import govukButton %}

  <form method="post">

    {% set errorList =[
      { text: errorMessages.genericErrorMessage.text, href: "#" } if errorMessages.genericErrorMessage else None,
      { text: errorMessages.witnessAvailability.text, href: "#witnessAvailability" } if errorMessages.witnessAvailability else None
    ] | reject("undefined") %}

    {% if errorMessages | length > 0 %}
      {% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
      {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
    {% endif %}

    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        {% include "pages/side-nav.njk" %}
      </div>

      <div class="govuk-grid-column-two-thirds">
        {% include "partials/review-required.njk" %}
        {% set alternateAddressHtml %}
          {{ govukSelect({
            id: "alternate-address",
            name: "alternateAddress",
            label: {
              text: "Please pick an alternative work location",
              classes: "govuk-fieldset__legend--m"
            },
            items: alternateAddressOptions
          }) }}
        {% endset -%}

        {% if not showEmbeddedError %}

          <h1 id="page-title" class="govuk-heading-l">Breach Report CO SSO – RO and Witness Details</h1>

          <h2 class="govuk-heading-m">Full name of RO</h2>
          <p id="name">{{ roName }}</p>

          <h2 class="govuk-heading-m">Probation Region</h2>
          <p id="probation-area">{{ witnessDetails.probationArea.description }}</p>

          <h2 class="govuk-heading-m">Work Location and Address</h2>
          {% if cosso.workAddress != null %}
              <p id="address">
                {% if cosso.workAddress.buildingName %} {{ cosso.workAddress.buildingName }}
                    <br/>{% endif %}
                {% if cosso.workAddress.buildingName or cosso.workAddress.streetName %} {{ cosso.workAddress.buildingNumber }} {{ cosso.workAddress.streetName }}
                    <br/>{% endif %}
                {% if cosso.workAddress.district %} {{ cosso.workAddress.district }}
                    <br/>{% endif %}
                {% if cosso.workAddress.townCity %} {{ cosso.workAddress.townCity }}
                    <br/>{% endif %}
                {% if cosso.workAddress.county %} {{ cosso.workAddress.county }}
                    <br/>{% endif %}
                {% if cosso.workAddress.postcode %} {{ cosso.workAddress.postcode }}
                    <br/>{% endif %}
              </p>
            {% if cosso.workAddress and not cosso.workAddress.addressId %}
              {{ govukButton({
                text: "Update Address",
                href: '/add-address/'+cossoId,
                classes: "govuk-button--secondary",
                preventDoubleClick: "true",
                attributes: {
                  id: "update-address-button"
                }
              }) }}
            {% endif %}
          {% elseif addressNotAvailable %}
              <p id="old-address-endDated"> Work Location and address: The previously selected address is no longer available. Please select an alternative </p>
          {% else %}
              <p id="no-valid-default">Please specify the Work Location and Address that the Person on Probation should contact.</p>
          {% endif %}

        {% if manualAddressAllowed and cosso.workAddress == null %}
          <p id="AddAddressMessage">No reply address can be found for this responsible officer. Please add an address by selecting the button below.</p>
          {{ govukButton({
            text: "Add Address",
            href: '/add-address/'+cossoId,
            classes: "govuk-button--secondary",
            preventDoubleClick: "true",
            attributes: {
              id: "add-address-button"
            }
          }) }}
        {% elseif not addressNotAvailable and witnessDetails.replyAddresses != null and witnessDetails.replyAddresses.length > 0 %}

          {{ govukRadios({
            name: "offenderAddressSelectOne",
            fieldset: {
              legend: {
                text: "Would you like to use the work location above for this Breach report CO SSO?",
                isPageHeading: false,
                classes: "govuk-fieldset__legend--m"
              }
            },
            hint: {
              text: "Select one option"
            },
            items: [
              {
                value: "Yes",
                text: "Yes",
                checked: cosso.workAddress != null
              },
              {
                value: "No",
                text: "No, I would like to use a different work location ",
                checked: cosso.workAddress == null or displayAlternate,
                conditional: {
                html: alternateAddressHtml
              }
              }
            ]
          }) }}

        {% elseif witnessDetails.replyAddresses != null and witnessDetails.replyAddresses.length > 0 %}

          {{ alternateAddressHtml | safe }}

        {% endif %}

          <h2 class="govuk-heading-m">Phone Number</h2>
          <p id="phone-number">{{ witnessDetails.telephoneNumber }}</p>

          <h2 class="govuk-heading-m">Email Address</h2>
          <p id="email-address">{{ witnessDetails.emailAddress }}</p>

          {% set witnessAvailabilityHelpHtml %}
            {{ govukDetails({
              summaryText: "What to include here",
              text: witnessAvailabilityHelp
            }) }}
          {% endset -%}
          {{ govukCharacterCount({
            label: {
              text: "Witness Availability",
              classes: "govuk-label--m",
              isPageHeading: false
            },
            hint : {
              html: witnessAvailabilityHelpHtml
            },
            value: cosso.witnessAvailability,
            classes: "govuk-input--width-30",
            name: "witnessAvailability",
            id: "witnessAvailability",
            maxlength: 20000,
            errorMessage: {
              text: errorMessages.witnessAvailability.text
            } if errorMessages.witnessAvailability.text
          }) }}

          <div class="moj-button-group">
            {{ govukButton({
              text: "Continue",
              preventDoubleClick: "true",
              type: "submit",
              attributes: {
                id: "continue-button"
              }
            }) }}
            {{ govukButton({
              text: "Save Progress and Close",
              type: "submit",
              name: "action",
              value: "saveProgressAndClose",
              classes: "govuk-button--secondary",
              attributes: {
                id: "close-button"
              }
            }) }}
          </div>

        {% endif %}
      </div>
    </div>

  </form>

{% endblock %}
